{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/nmatsumoto/blog/.github/agent/acceptance.schema.json",
  "title": "Loop Agent Acceptance Criteria",
  "type": "object",
  "additionalProperties": false,
  "required": ["acceptance_criteria"],
  "properties": {
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "pnpm run typecheck",
          "pnpm run lint",
          "pnpm run test",
          "pnpm run build"
        ]
      },
      "uniqueItems": true
    },
    "scope": {
      "type": "string",
      "minLength": 1
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
